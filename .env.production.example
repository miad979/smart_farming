# Runtime host (Node web service)
NODE_ENV=production
VITE_API_BASE_URL=/api

# Required security settings
AUTH_TOKEN_SECRET=replace_with_a_long_random_value
FORCE_SECURE_COOKIES=true
AUTH_COOKIE_SAME_SITE=Lax
CSRF_COOKIE_SAME_SITE=Lax
CORS_ALLOWED_ORIGINS=https://smart-farming-runtime.onrender.com

# Optional CSP tuning
# CONTENT_SECURITY_POLICY=default-src 'self'; ...
# CSP_REPORT_ONLY=false
# CSP_EXTRA_CONNECT_SRC=https://another-api.example.com,wss://another-stream.example.com

# Optional request throttling overrides (production defaults are already hardened)
# RATE_LIMIT_GLOBAL_PER_MINUTE=120
# RATE_LIMIT_SIGNIN_PER_10_MINUTES=20
# RATE_LIMIT_SIGNUP_PER_10_MINUTES=10
# RATE_LIMIT_UPLOADS_PER_5_MINUTES=20
# RATE_LIMIT_USERS_MUTATION_PER_MINUTE=40
# RATE_LIMIT_DOCTOR_VERIFY_PER_MINUTE=30
# RATE_LIMIT_SIGNIN_EMAIL_PER_10_MINUTES=8
# RATE_LIMIT_REALTIME_CONNECT_PER_MINUTE=20
# RATE_LIMIT_REALTIME_CONNECTIONS_PER_IP=5

# Market realtime behavior profile
# Allowed: stable | balanced | aggressive
MARKET_VOLATILITY_PROFILE=balanced
# Optional explicit interval override in milliseconds (profile default is usually best)
# MARKET_REALTIME_AUTO_UPDATE_MS=30000

# Optional PostgreSQL snapshot storage
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME
SQL_SSL=require

# Crop disease detection
PLANT_ID_API_KEY=your_real_plant_id_api_key
PLANT_ID_HEALTH_ENDPOINT=https://api.plant.id/v2/health_assessment

# Optional chat assistant providers (fallback order: OpenAI -> Groq -> OpenRouter)
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini

GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.1-8b-instant

OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_MODEL=meta-llama/llama-3.3-8b-instruct:free
OPENROUTER_SITE_URL=https://smart-farming-runtime.onrender.com
OPENROUTER_APP_NAME=Smart Farming

# Optional natural voice output
EDGE_TTS_ENABLED=true
EDGE_TTS_BN_VOICE=bn-BD-PradeepNeural
EDGE_TTS_EN_VOICE=en-US-AriaNeural
EDGE_TTS_BN_RATE=-10%
EDGE_TTS_EN_RATE=default
