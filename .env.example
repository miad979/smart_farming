# Backend/API settings
VITE_API_BASE_URL=/api

# For deployment to a runtime host, start from .env.production.example

# Cookie/security controls
# FORCE_SECURE_COOKIES=false
# AUTH_COOKIE_SAME_SITE=Lax
# CSRF_COOKIE_SAME_SITE=Lax

# Optional request throttling overrides
# RATE_LIMIT_GLOBAL_PER_MINUTE=240
# RATE_LIMIT_SIGNIN_PER_10_MINUTES=50
# RATE_LIMIT_SIGNUP_PER_10_MINUTES=20
# RATE_LIMIT_UPLOADS_PER_5_MINUTES=30
# RATE_LIMIT_USERS_MUTATION_PER_MINUTE=80
# RATE_LIMIT_DOCTOR_VERIFY_PER_MINUTE=60
# RATE_LIMIT_SIGNIN_EMAIL_PER_10_MINUTES=12
# RATE_LIMIT_REALTIME_CONNECT_PER_MINUTE=40
# RATE_LIMIT_REALTIME_CONNECTIONS_PER_IP=20

# Optional PostgreSQL snapshot storage
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME
# Set to require for managed Postgres providers when SSL is mandatory
SQL_SSL=require

# Supabase PostgreSQL shortcut (optional)
# You can use either DATABASE_URL above, or this Supabase pair:
# SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# SUPABASE_DB_PASSWORD=your_database_password
# Optional explicit Supabase DB URL (takes priority over SUPABASE_URL+SUPABASE_DB_PASSWORD)
# SUPABASE_DB_URL=postgresql://postgres:password@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# Plant.id Crop Disease Detection API
PLANT_ID_API_KEY=your_real_plant_id_api_key
PLANT_ID_HEALTH_ENDPOINT=https://api.plant.id/v2/health_assessment

# Optional chat assistant providers (tried in this order: OpenAI -> Groq -> OpenRouter)
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini

# Groq offers free-tier usage for many accounts
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.1-8b-instant

# OpenRouter can be used with free models
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_MODEL=meta-llama/llama-3.3-8b-instruct:free
OPENROUTER_SITE_URL=http://localhost:5173
OPENROUTER_APP_NAME=Smart Farming

# Optional high-quality neural TTS (enabled by default, no paid key required)
EDGE_TTS_ENABLED=true
EDGE_TTS_BN_VOICE=bn-BD-PradeepNeural
EDGE_TTS_EN_VOICE=en-US-AriaNeural
EDGE_TTS_BN_RATE=-10%
EDGE_TTS_EN_RATE=default
